# Allow the deploy user to recycle only the services touched by deploy.sh and rollback.sh.
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl reload nginx
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl reload php8.3-fpm
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl reload eventovivo-horizon
deploy ALL=(root) NOPASSWD: /usr/bin/systemctl reload eventovivo-reverb
