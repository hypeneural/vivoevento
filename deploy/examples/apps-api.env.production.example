# Evento Vivo API - production example
# Required values must be replaced before go-live.

# required: app identity
APP_NAME="Evento Vivo"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.eventovivo.com.br
FRONTEND_URL=https://admin.eventovivo.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# required: logging
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_WALL_REALTIME_CHANNEL=wall-realtime
LOG_QUEUE_TELEMETRY_CHANNEL=queue-telemetry

# required: database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eventovivo
DB_USERNAME=eventovivo
DB_PASSWORD=

# required: session and cookies
SESSION_DRIVER=redis
SESSION_CONNECTION=cache
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.eventovivo.com.br
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# required: queue, cache and broadcast
QUEUE_CONNECTION=redis
CACHE_STORE=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_FAILED_DRIVER=database-uuids
SANCTUM_STATEFUL_DOMAINS=admin.eventovivo.com.br

# required: redis
# DB separation helps organization, but does not isolate eviction policy.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_RETRY_AFTER=240
REDIS_QUEUE_BLOCK_FOR=5
REDIS_QUEUE_AFTER_COMMIT=true
QUEUE_MONITOR_CONNECTION=redis
QUEUE_BUSY_WEBHOOKS_MAX=25
QUEUE_BUSY_MEDIA_FAST_MAX=50
QUEUE_BUSY_MEDIA_PUBLISH_MAX=25
QUEUE_BUSY_BROADCASTS_MAX=50
OPERATIONS_DASHBOARD_ROLES=super-admin,platform-admin
OPERATIONS_DASHBOARD_PERMISSION=audit.view
OPS_DEGRADE_MEDIA_SAFETY_MODE=normal
OPS_DEGRADE_MEDIA_VLM_ENABLED=true
OPS_DEGRADE_FACE_INDEX_ENABLED=true

# required: mail
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@eventovivo.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# required: object storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# required: reverb runtime and public ws host
REVERB_APP_ID=eventovivo
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080
REVERB_HOST=ws.eventovivo.com.br
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_ALLOWED_ORIGINS=https://admin.eventovivo.com.br,https://eventovivo.com.br

# optional: horizon tuning
HORIZON_WAIT_BROADCASTS=10
HORIZON_WAIT_FACE_INDEX=180
HORIZON_WAIT_MEDIA_FAST=45
HORIZON_WAIT_MEDIA_PROCESS=90
HORIZON_WAIT_MEDIA_SAFETY=60
HORIZON_WAIT_MEDIA_VLM=90
HORIZON_WAIT_MEDIA_PUBLISH=30
HORIZON_BROADCASTS_MIN_PROCESSES=1
HORIZON_BROADCASTS_MAX_PROCESSES=2
HORIZON_WEBHOOKS_MIN_PROCESSES=1
HORIZON_WEBHOOKS_MAX_PROCESSES=2
HORIZON_MEDIA_DOWNLOAD_MIN_PROCESSES=1
HORIZON_MEDIA_DOWNLOAD_MAX_PROCESSES=3
HORIZON_MEDIA_FAST_MIN_PROCESSES=1
HORIZON_FACE_INDEX_MAX_PROCESSES=2
HORIZON_FACE_INDEX_MIN_PROCESSES=1
HORIZON_MEDIA_FAST_MAX_PROCESSES=2
HORIZON_MEDIA_PROCESS_MIN_PROCESSES=1
HORIZON_MEDIA_PROCESS_MAX_PROCESSES=3
HORIZON_MEDIA_SAFETY_MIN_PROCESSES=1
HORIZON_MEDIA_SAFETY_MAX_PROCESSES=2
HORIZON_MEDIA_VLM_MIN_PROCESSES=1
HORIZON_MEDIA_VLM_MAX_PROCESSES=2
HORIZON_MEDIA_PUBLISH_MIN_PROCESSES=1
HORIZON_MEDIA_PUBLISH_MAX_PROCESSES=2
HORIZON_NOTIFICATIONS_MIN_PROCESSES=1
HORIZON_NOTIFICATIONS_MAX_PROCESSES=2
HORIZON_DEFAULT_MIN_PROCESSES=1
HORIZON_DEFAULT_MAX_PROCESSES=2

# optional: whatsapp provider
WHATSAPP_DEFAULT_PROVIDER=zapi
WHATSAPP_AUTH_INSTANCE_ID=
WHATSAPP_AUTH_ALLOW_ENV_SENDER_IN_TESTING=false
WHATSAPP_AUTH_ZAPI_INSTANCE_ID=
WHATSAPP_AUTH_ZAPI_TOKEN=
WHATSAPP_AUTH_ZAPI_CLIENT_TOKEN=
BILLING_ACCESS_WHATSAPP_INSTANCE_ID=
BILLING_ACCESS_ALLOW_SINGLE_CONNECTED_FALLBACK=true
BILLING_PAYMENT_NOTIFICATIONS_ENABLED=true
BILLING_PAYMENT_NOTIFICATIONS_WHATSAPP_INSTANCE_ID=
BILLING_PAYMENT_NOTIFICATIONS_ALLOW_SINGLE_CONNECTED_FALLBACK=true

# optional: external safety moderation
# Keep noop if AI moderation is not part of the first go-live.
CONTENT_MODERATION_PROVIDER=noop
# CONTENT_MODERATION_PROVIDER=openai
CONTENT_MODERATION_OPENAI_MODEL=omni-moderation-latest
CONTENT_MODERATION_OPENAI_MODEL_SNAPSHOT=
CONTENT_MODERATION_OPENAI_TIMEOUT=15
CONTENT_MODERATION_OPENAI_CONNECT_TIMEOUT=5
CONTENT_MODERATION_OPENAI_PROVIDER_VERSION=openai-http-v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# optional: media intelligence
# Base go-live keeps this disabled unless an external provider is explicitly ready.
MEDIA_INTELLIGENCE_PROVIDER=noop
MEDIA_INTELLIGENCE_VLLM_BASE_URL=
MEDIA_INTELLIGENCE_VLLM_API_KEY=
MEDIA_INTELLIGENCE_VLLM_MODEL=
MEDIA_INTELLIGENCE_VLLM_MODEL_SNAPSHOT=
MEDIA_INTELLIGENCE_VLLM_TIMEOUT=20
MEDIA_INTELLIGENCE_VLLM_CONNECT_TIMEOUT=5
MEDIA_INTELLIGENCE_VLLM_PROVIDER_VERSION=vllm-openai-v1
MEDIA_INTELLIGENCE_VLLM_TEMPERATURE=0.1
MEDIA_INTELLIGENCE_VLLM_MAX_COMPLETION_TOKENS=300

# optional: face search
# Keep noop until the feature is explicitly enabled and validated.
FACE_SEARCH_DETECTION_PROVIDER=noop
FACE_SEARCH_EMBEDDING_PROVIDER=noop
FACE_SEARCH_VECTOR_STORE=pgvector
FACE_SEARCH_EMBEDDING_MODEL=face-embedding-foundation-v1
FACE_SEARCH_EMBEDDING_DIMENSION=512
FACE_SEARCH_CROP_DISK=ai-private
FACE_SEARCH_MIN_FACE_SIZE_PX=96
FACE_SEARCH_MIN_QUALITY_SCORE=0.60
FACE_SEARCH_SEARCH_THRESHOLD=0.35
FACE_SEARCH_TOP_K=50
