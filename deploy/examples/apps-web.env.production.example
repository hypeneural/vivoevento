# Evento Vivo admin app - production example

# required: API and app URLs
VITE_API_BASE_URL=https://api.eventovivo.com.br/api/v1
VITE_APP_URL=https://admin.eventovivo.com.br
VITE_PAGARME_PUBLIC_KEY=

# required: reverb public connection
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=ws.eventovivo.com.br
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# required: feature flags for production
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_BILLING=false
VITE_USE_MOCK=false
