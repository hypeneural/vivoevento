# ──────────────────────────────────────────────────────────────
# Evento Vivo — Environment Variables
# ──────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
APP_NAME="Evento Vivo"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Database (PostgreSQL) ──────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eventovivo
DB_USERNAME=eventovivo
DB_PASSWORD=secret

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=secret

# ─── Cache / Queue / Session ────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Storage (MinIO / S3) ──────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=eventovivo
AWS_SECRET_ACCESS_KEY=secret123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=eventovivo-media
AWS_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── Mail (Mailpit) ────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@eventovivo.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Broadcasting (Reverb) ─────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=eventovivo
REVERB_APP_KEY=eventovivo-key
REVERB_APP_SECRET=eventovivo-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Horizon ───────────────────────────────────────────────
HORIZON_PREFIX=eventovivo_horizon:

# ─── Telescope ─────────────────────────────────────────────
TELESCOPE_ENABLED=true

# ─── Pulse ──────────────────────────────────────────────────
PULSE_ENABLED=true

# ─── Sanctum ───────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:5173

# ─── Billing (futuro) ──────────────────────────────────────
# STRIPE_KEY=
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=
